{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LangGraph Dev",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\.venv\\Scripts\\langgraph.exe",
            "args": [
                "dev",
                // "--no-browser",
                "--allow-blocking",
                "--no-reload"
            ],
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "justMyCode": false
        },
        {
            "name": "Python: Uvicorn",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.gateway.app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8001"
            ],
            "jinja": true
        }
    ]
}